# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin ─────────────────────────────────────────────────────────────────────
# The wallet address that can access /admin (lowercase, no ENS)
NEXT_PUBLIC_ADMIN_WALLET=0xyour_admin_wallet_address

# ── Arc Testnet ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# ── WalletConnect (optional - for QR code support) ───────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=get_from_cloud.walletconnect.com

# ── AI (set in Admin panel UI, but can pre-set here) ─────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...
